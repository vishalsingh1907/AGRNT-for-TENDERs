# ═══════════════════════════════════════════════════════════
# Tender Monitoring Agent — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
# Docker Compose overrides these — only needed for local dev
DATABASE_URL=sqlite+aiosqlite:///tender_agent.db
DATABASE_URL_SYNC=sqlite:///tender_agent.db
DB_PASSWORD=tender_pass

# ── AI Provider ───────────────────────────────────────────
# Primary: gemini | Fallback: openai
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# Get your Gemini API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) OpenAI fallback
OPENAI_API_KEY=

# Max AI API requests per minute
AI_MAX_RPM=10

# ── Telegram ─────────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram
# 2. Get the bot token
# 3. Add the bot to your group/channel
# 4. Get the chat ID (use @userinfobot or API)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Scraping ─────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
SCRAPE_TIMEOUT_MS=60000
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=5.0
MAX_PAGES_PER_SOURCE=10

# ── Relevance ────────────────────────────────────────────
# Only send notifications for tenders scoring above this
RELEVANCE_THRESHOLD=75

# ── Paths ────────────────────────────────────────────────
PDF_DOWNLOAD_DIR=./downloads
SOURCES_CONFIG_PATH=./config/sources.yaml

# ── Dashboard ────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
